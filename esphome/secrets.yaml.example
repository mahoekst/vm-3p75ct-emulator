# Copy this file to secrets.yaml and fill in your actual values.
# secrets.yaml is git-ignored and must never be committed.

wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# Generate with: python3 -m esphome gen-api-key
esphome_api_key: "base64-encoded-32-byte-key-here="
esphome_api_password: "changeme"

esphome_ota_password: "changeme"

esphome_ap_ssid: "ESPHome"
esphome_ap_password: "changeme"
